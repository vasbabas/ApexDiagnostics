<UserControl x:Class="ApexDiagnostics.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="0,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{DynamicResource TitleSystemInfo}" Style="{StaticResource SectionHeader}" FontSize="22" TextWrapping="Wrap"/>
                <TextBlock Text="{DynamicResource ClickToCopy}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="CREATE WINPE ISO" Style="{StaticResource AccentButton}" Command="{Binding OpenBuilderCommand}" Margin="0,0,10,0" Width="140" Height="32">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="10" Color="#58A6FF" Opacity="0.3" ShadowDepth="0"/>
                    </Button.Effect>
                </Button>
                <Button Content="EXPORT REPORT" Style="{StaticResource GhostButton}" Command="{Binding ExportCommand}" Margin="0,0,10,0" Width="140" Height="32"/>
                <Button Content="REFRESH" Style="{StaticResource GhostButton}" Command="{Binding RefreshCommand}" Width="100" Height="32"/>
            </StackPanel>
        </Grid>

        <!-- Body specs list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Category Card -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
                            <DockPanel>
                                <!-- Category Title Header -->
                                <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="#21262D" Padding="0,0,0,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Glowing Category Bullet -->
                                        <Border Grid.Column="0" Width="8" Height="18" Background="{StaticResource AccentBlueBrush}" CornerRadius="2.5" Margin="0,0,12,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" Color="#58A6FF" Opacity="0.7" ShadowDepth="0"/>
                                            </Border.Effect>
                                        </Border>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Sleek Inventory Rows -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid x:Name="RowGrid" Background="Transparent" Margin="0,1">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Resources>
                                                            <Storyboard x:Key="OnHover">
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="6,1,0,1" Duration="0:0:0.12"/>
                                                            </Storyboard>
                                                            <Storyboard x:Key="OnLeave">
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0,1,0,1" Duration="0:0:0.12"/>
                                                            </Storyboard>
                                                        </Style.Resources>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard Storyboard="{StaticResource OnHover}"/>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard Storyboard="{StaticResource OnLeave}"/>
                                                                </Trigger.ExitActions>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                
                                                <!-- Row Visual Separator Line -->
                                                <Border BorderThickness="0,0,0,1" BorderBrush="#08FFFFFF" Padding="4,6">
                                                    <Grid>
                                                        <!-- Regular Row -->
                                                        <Grid x:Name="RegularRow">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Property}" Foreground="#8B949E" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                            <!-- Using TextBox to make value copyable/selectable with keyboard, but styled like TextBlock -->
                                                            <TextBox Grid.Column="1" Text="{Binding Value}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" 
                                                                     Background="Transparent" BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap" SelectionBrush="#58A6FF"/>
                                                        </Grid>
                                                        
                                                        <!-- Header Splitter Row -->
                                                        <Grid x:Name="SplitterRow" Visibility="Collapsed">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Property}" Foreground="{StaticResource AccentBlueBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,2,10,2" TextWrapping="Wrap"/>
                                                            <Separator Grid.Column="1" Background="#2658A6FF" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <!-- Show visual separator splitter style if the property starts with "-" -->
                                                <DataTrigger Binding="{Binding Property, Converter={StaticResource StringStartsWithConverter}, ConverterParameter='-'}" Value="True">
                                                    <Setter TargetName="RegularRow" Property="Visibility" Value="Collapsed"/>
                                                    <Setter TargetName="SplitterRow" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="RowGrid" Property="Background" Value="Transparent"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- WinPE Builder Overlay Dialog -->
        <Grid Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsBuilderVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Style="{StaticResource CardBorder}" Background="{StaticResource BgSurfaceBrush}" 
                    BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Width="600" Height="500" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title & Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="⚡ Bootable WinPE ISO Creator" Foreground="{StaticResource AccentBlueBrush}" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Compile and package the Apex Diagnostics Suite into a bootable Windows PE ISO." FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" Padding="0" Command="{Binding CloseBuilderCommand}"/>
                    </Grid>

                    <!-- Config Parameters -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <!-- ADK Path -->
                        <TextBlock Text="WINDOWS ADK PATH" FontSize="9" Opacity="0.5" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <TextBox Text="{Binding AdkPath, Mode=TwoWay}" Background="#1FFFFFFF" Foreground="White" BorderBrush="#33FFFFFF" BorderThickness="1" SelectionBrush="#58A6FF" Height="30" Padding="5,5,80,5" VerticalContentAlignment="Center"/>
                            <Button Content="BROWSE" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Width="70" Height="28" Margin="1" Command="{Binding BrowseAdkCommand}"/>
                        </Grid>

                        <!-- ISO Save Path -->
                        <TextBlock Text="OUTPUT ISO SAVE PATH" FontSize="9" Opacity="0.5" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <TextBox Text="{Binding IsoOutputPath, Mode=TwoWay}" Background="#1FFFFFFF" Foreground="White" BorderBrush="#33FFFFFF" BorderThickness="1" SelectionBrush="#58A6FF" Height="30" Padding="5,5,80,5" VerticalContentAlignment="Center"/>
                            <Button Content="BROWSE" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Width="70" Height="28" Margin="1" Command="{Binding BrowseIsoCommand}"/>
                        </Grid>

                        <!-- Compile Source Checkbox -->
                        <CheckBox IsChecked="{Binding CompileBeforeBuild, Mode=TwoWay}" Margin="0,0,0,5" VerticalAlignment="Center">
                            <TextBlock Text="Build fresh source code before packaging (dotnet publish)" FontSize="11" Foreground="White"/>
                        </CheckBox>
                    </StackPanel>

                    <!-- Scrolling Live Logger Output -->
                    <Border Grid.Row="2" Background="#111" CornerRadius="4" BorderBrush="#222" BorderThickness="1" Padding="8">
                        <TextBox Text="{Binding BuilderLogText, Mode=OneWay}" 
                                 Background="Transparent" BorderThickness="0" Foreground="#3FB950" 
                                 FontFamily="Consolas" FontSize="10" IsReadOnly="True" 
                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                                 x:Name="LogTextBox" SelectionBrush="#58A6FF" TextChanged="LogTextBox_TextChanged"/>
                    </Border>

                    <!-- Action Footer -->
                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <TextBlock Text="Compilation requires Windows ADK + PE Addon." FontSize="10" Opacity="0.4" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="CLOSE" Style="{StaticResource GhostButton}" Width="100" Height="32" Margin="0,0,10,0" Command="{Binding CloseBuilderCommand}" IsEnabled="{Binding IsNotBuilding}"/>
                            <Button Content="GENERATE ISO" Style="{StaticResource AccentButton}" Width="130" Height="32" Command="{Binding BuildIsoCommand}" IsEnabled="{Binding IsNotBuilding}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
