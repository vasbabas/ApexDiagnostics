<UserControl x:Class="ApexDiagnostics.Views.RamTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:ApexDiagnostics.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="0,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{DynamicResource TitleRamTest}" Style="{StaticResource SectionHeader}" FontSize="22" TextWrapping="Wrap"/>
                
                <UniformGrid Columns="4" Margin="0,10,0,0">
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LabelCpuStatus}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding EngineStatus, Converter={StaticResource StatusTextConverter}}" Style="{StaticResource MetricHero}" FontSize="20" 
                                       Foreground="{Binding EngineStatus, Converter={StaticResource StatusColorConverter}}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LabelPass}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentPass}" Style="{StaticResource MetricHero}" FontSize="20" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LabelErrors}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding TotalErrors}" Style="{StaticResource MetricHero}" FontSize="20" 
                                       Foreground="{Binding TotalErrors, Converter={StaticResource ErrorColorConverter}}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LabelElapsedTime}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ElapsedTime}" Style="{StaticResource MetricHero}" FontSize="20" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0">
                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                    <RadioButton Content="{DynamicResource LabelQuickScan}" IsChecked="{Binding IsDeepMode, Converter={StaticResource InverseBooleanConverter}}" Foreground="White" Margin="0,0,0,5"/>
                    <RadioButton Content="{DynamicResource LabelDeepValidation}" IsChecked="{Binding IsDeepMode}" Foreground="White"/>
                </StackPanel>
                <Button Content="{DynamicResource BtnStartTest}" Style="{StaticResource GreenButton}" Command="{Binding StartCommand}" Width="Auto" MinWidth="130" Padding="15,0" Height="32" Margin="0,0,10,0"
                        Visibility="{Binding EngineStatus, Converter={StaticResource StartButtonVisibilityConverter}}"/>
                <Button Content="{DynamicResource BtnStopTest}" Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" Width="Auto" MinWidth="130" Padding="15,0" Height="32"
                        Visibility="{Binding EngineStatus, Converter={StaticResource StopButtonVisibilityConverter}}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Progress & Patterns -->
            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelCurrentTest}" Style="{StaticResource MetricLabel}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding CurrentTestName}" FontSize="16" FontWeight="Bold" Margin="0,5,0,12" TextWrapping="Wrap"/>
                        
                        <ProgressBar Value="{Binding TestProgress, Mode=OneWay}" Height="24"/>
                        <Grid Margin="0,5,0,0">
                            <TextBlock Text="{Binding AllocatedMB, StringFormat={}{0} MB}" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Text="{Binding TargetMB, StringFormat={}{0} MB}" Style="{StaticResource MetricLabel}" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding TestProgress, Mode=OneWay, StringFormat={}{0:F1}%}" HorizontalAlignment="Center" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Memory Map Visualization -->
                <TextBlock Text="{DynamicResource LabelPhysicalMemoryMap}" Style="{StaticResource MetricLabel}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                <Border Style="{StaticResource CardBorder}" Height="200" Padding="8">
                    <controls:SectorMapControl x:Name="MemoryMap" Margin="2"
                                               MapData="{Binding MapData}"
                                               TotalSectors="{Binding TargetMB}" 
                                               ScannedSectors="{Binding AllocatedMB}"/>
                </Border>
            </StackPanel>

            <!-- Error Log -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{DynamicResource LabelErrors}" Style="{StaticResource SectionHeader}" FontSize="15" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    
                    <ListBox Grid.Row="1" ItemsSource="{Binding Faults}" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TestName}" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}" TextWrapping="Wrap"/>
                                        <TextBlock FontSize="10.5" TextWrapping="Wrap">
                                            <Run Text="Offset: 0x"/>
                                            <Run Text="{Binding Offset, StringFormat=X}"/>
                                            <Run Text=" │ Exp: "/>
                                            <Run Text="{Binding Expected, StringFormat=X2}"/>
                                            <Run Text=" │ Act: "/>
                                            <Run Text="{Binding Actual, StringFormat=X2}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1" Text="{DynamicResource LabelNoErrors}" Style="{StaticResource GoodText}" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                               Visibility="{Binding TotalErrors, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
