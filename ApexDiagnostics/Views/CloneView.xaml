<UserControl x:Class="ApexDiagnostics.Views.CloneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="0,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{DynamicResource TitleClone}" Style="{StaticResource SectionHeader}" FontSize="22" TextWrapping="Wrap"/>
                <TextBlock Text="{DynamicResource TitleCloneDesc}" Style="{StaticResource MetricLabel}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{DynamicResource BtnRefreshDrives}" Style="{StaticResource GhostButton}" Command="{Binding RefreshDisksCommand}" Width="150" Height="32" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource BtnStartCloning}" Style="{StaticResource GreenButton}" Command="{Binding ShowWarningCommand}" Width="150" Height="32"/>
            </StackPanel>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Drive Selection -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SelectSourceDisk}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ComboBox ItemsSource="{Binding Disks}" SelectedItem="{Binding SelectedSource}" DisplayMemberPath="DisplayName" Height="38" Margin="0,0,0,25" IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBooleanConverter}}"/>

                    <TextBlock Text="{DynamicResource SelectTargetDisk}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ComboBox ItemsSource="{Binding Disks}" SelectedItem="{Binding SelectedDest}" DisplayMemberPath="DisplayName" Height="38" Margin="0,0,0,25" IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Border Style="{StaticResource InnerCardBorder}" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1" Padding="15">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource CloningInfoTitle}" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource CloningInfo1}" Foreground="#A0FFFFFF" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource CloningInfo2}" Foreground="#A0FFFFFF" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource CloningInfo3}" Foreground="{StaticResource AccentOrangeBrush}" FontSize="10.5" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Right Panel: Diagnostics Telemetry -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Telemetry Stats Grid -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{DynamicResource CloneTelemetryTitle}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,15" TextWrapping="Wrap"/>
                        
                        <UniformGrid Columns="2" Rows="2" Margin="0,0,0,20">
                            <Border Style="{StaticResource InnerCardBorder}" Margin="0,0,8,8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CloneSpeed}" Style="{StaticResource MetricLabel}" FontSize="9" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SpeedMBs, StringFormat={}{0:F1} MB/s}" Style="{StaticResource MetricHero}" FontSize="18" Foreground="{StaticResource AccentYellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCardBorder}" Margin="8,0,0,8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CloneTimeRemaining}" Style="{StaticResource MetricLabel}" FontSize="9" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TimeRemaining}" Style="{StaticResource MetricHero}" FontSize="18" Foreground="{StaticResource AccentCyanBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCardBorder}" Margin="0,8,8,0" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CloneSourceIndex}" Style="{StaticResource MetricLabel}" FontSize="9" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedSource.Index, TargetNullValue='N/A', StringFormat='Drive #{0}'}" Style="{StaticResource MetricHero}" FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCardBorder}" Margin="8,8,0,0" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CloneTargetIndex}" Style="{StaticResource MetricLabel}" FontSize="9" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedDest.Index, TargetNullValue='N/A', StringFormat='Drive #{0}'}" Style="{StaticResource MetricHero}" FontSize="18" Foreground="{StaticResource AccentRedBrush}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Large Progress Bar and Text -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" Margin="0,0,0,8" TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Value="{Binding Progress}" Height="18" Foreground="#FF17C3B2" Background="#20FFFFFF"/>
                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F1}%}" Foreground="#FF17C3B2" FontWeight="Bold" FontSize="15" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Icon -->
                    <Border Grid.Row="2" Style="{StaticResource InnerCardBorder}" Background="#05FFFFFF" Padding="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="14" Foreground="{StaticResource AccentYellowBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource CloneEngineActive}" Foreground="#80FFFFFF" FontSize="10.5" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- OVERLAY WARNING POPUP -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#C0000000" Visibility="{Binding IsWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Style="{StaticResource CardBorder}" BorderBrush="{StaticResource AccentRedBrush}" BorderThickness="2"
                    Width="500" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{DynamicResource CloneWarningTitle}" Foreground="{StaticResource AccentRedBrush}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource CloneWarningSubtitle}" Style="{StaticResource MetricLabel}" Margin="0,4,0,15" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="{DynamicResource CloneWarningText}" Foreground="White" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        
                        <!-- Pulse Danger Wipe Box -->
                        <Border Background="#30F85149" BorderBrush="{StaticResource AccentRedBrush}" BorderThickness="2" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Source (Safe Read-Only) -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource CloneSourceLabel}" Foreground="{StaticResource AccentGreenBrush}" FontSize="10.5" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedSource.DisplayName}" Foreground="White" FontSize="10.5" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Right"/>
                                </Grid>
                                
                                <Separator Background="#40FFFFFF" Margin="0,4,0,6"/>
                                
                                <!-- DESTINATION (DANGER - COMPLETELY WIPE!) -->
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CloneTargetWarningLabel}" Foreground="{StaticResource AccentRedBrush}" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <Border Background="#40000000" CornerRadius="4" Padding="8">
                                        <TextBlock Text="{Binding SelectedDest.DisplayName}" Foreground="{StaticResource AccentRedBrush}" FontSize="13" FontWeight="Black" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource CloneWipeNote}" Foreground="{StaticResource AccentRedBrush}" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource CloneWarningConfirmText}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBox Text="{Binding ConfirmText, UpdateSourceTrigger=PropertyChanged}" Height="34" Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CaretBrush="White"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="{DynamicResource BtnCancel}" Command="{Binding CancelWarningCommand}" Style="{StaticResource GhostButton}" Width="100" Height="32" Margin="0,0,10,0"/>
                        <Button Content="{DynamicResource BtnWipeClone}" Command="{Binding StartCloneCommand}" Style="{StaticResource DangerButton}" Width="150" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
