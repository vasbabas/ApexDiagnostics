<UserControl x:Class="ApexDiagnostics.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ApexDiagnostics.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource TitleExplorer}" Style="{StaticResource SectionHeader}" FontSize="22" Margin="0,0,0,15" TextWrapping="Wrap"/>

        <!-- Top Tool Bar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⬆ UP" Command="{Binding NavigateUpCommand}" Style="{StaticResource AccentButton}" Padding="10,4" Height="30" Margin="0,0,6,0"/>
                    <Button Content="📁+ NEW" Command="{Binding CreateFolderCommand}" Style="{StaticResource AccentButton}" Padding="10,4" Height="30" Margin="0,0,6,0"/>
                    <Button Content="📋 COPY" Command="{Binding CopyCommand}" Style="{StaticResource AccentButton}" Padding="10,4" Height="30" Margin="0,0,6,0"/>
                    <Button Content="📥 PASTE" Command="{Binding PasteCommand}" Style="{StaticResource AccentButton}" Padding="10,4" Height="30" Margin="0,0,6,0"/>
                    <Button Content="❌ DELETE" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Padding="10,4" Height="30" Margin="0,0,12,0"/>
                </StackPanel>

                <!-- Current Address TextBox -->
                <Border Grid.Column="1" Style="{StaticResource InnerCardBorder}" Padding="8,4" Height="32" VerticalAlignment="Center">
                    <TextBox Text="{Binding CurrentDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent" BorderThickness="0" Foreground="White" 
                             FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center"/>
                </Border>

                <!-- Glowing Quick Data Recovery Button -->
                <Button Grid.Column="2" Content="{DynamicResource BtnBackupWizard}" Command="{Binding ShowBackupWizardCommand}" 
                        Background="#FF17C3B2" Foreground="Black" FontWeight="Bold" FontSize="11" 
                        Width="Auto" MinWidth="140" Padding="12,0" Height="32" Margin="15,0,0,0" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF20DFCC"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="10" Color="#FF17C3B2" Opacity="0.5"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Drives List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,15,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{DynamicResource LabelAvailableDrives}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    
                    <ListBox Grid.Row="1" ItemsSource="{Binding Drives}" SelectedItem="{Binding CurrentDirectory}" 
                             Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="DriveCard" Margin="0,0,0,8" Padding="10" CornerRadius="4" 
                                                    Background="#0DFFFFFF" BorderThickness="1" BorderBrush="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="💾 " FontSize="14"/>
                                                    <TextBlock Text="{Binding}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="DriveCard" Property="Background" Value="#1A58A6FF"/>
                                                    <Setter TargetName="DriveCard" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="DriveCard" Property="Background" Value="#15FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right Panel: Files List -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Columns Header -->
                    <Grid Grid.Row="0" Margin="10,8" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource LabelFileName}" Style="{StaticResource MetricLabel}" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource LabelFileSize}" Style="{StaticResource MetricLabel}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="{DynamicResource LabelFileModified}" Style="{StaticResource MetricLabel}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                             Background="Transparent" BorderThickness="0" MouseDoubleClick="ListBox_MouseDoubleClick"
                             HorizontalContentAlignment="Stretch"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="FileRow" Padding="10,8" Margin="0,0,0,4" CornerRadius="4"
                                                    Background="Transparent" BorderThickness="0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="150"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding Size}" Foreground="{Binding Color}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding LastModified}" Foreground="#8B949E" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="FileRow" Property="Background" Value="#1558A6FF"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="FileRow" Property="Background" Value="#08FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Asynchronous Data Recovery Wizard Overlay -->
        <Grid Grid.RowSpan="3" Background="#90000000" Visibility="{Binding IsBackupWizardVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Style="{StaticResource CardBorder}" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1.5"
                    Width="520" Height="680" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Wizard Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="{DynamicResource WizardTitle}" Foreground="{StaticResource AccentBlueBrush}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="Rescue user profiles and system vault credentials from local drives." Style="{StaticResource MetricLabel}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Wizard Steps / Fields (Config Panel) -->
                    <StackPanel Grid.Row="1" Margin="0,5">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPreviewVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <!-- Step 1: Select User profile -->
                        <TextBlock Text="{DynamicResource WizSelectProfile}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <ComboBox ItemsSource="{Binding UserProfiles}" SelectedItem="{Binding SelectedUserProfile}" 
                                  IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                  Height="36" Margin="0,0,0,18"/>

                        <!-- Step 2: Select Destination backup folder -->
                        <TextBlock Text="{DynamicResource WizSelectDest}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource InnerCardBorder}" Padding="8,4" Height="36" VerticalAlignment="Center" CornerRadius="6,0,0,6">
                                <TextBox Text="{Binding SelectedBackupDest}" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" IsReadOnly="True" FontSize="11"/>
                            </Border>
                            <Button Grid.Column="1" Content="{DynamicResource BtnBrowse}" Command="{Binding BrowseBackupDestCommand}" 
                                    Style="{StaticResource AccentButton}" Height="36" MinWidth="90" Padding="12,0" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Step 3: Extra Backups -->
                        <TextBlock Text="{DynamicResource WizSelectOptions}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <CheckBox Content="{DynamicResource WizOptCreds}" 
                                  IsChecked="{Binding BackupCredentials}" 
                                  IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                  Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="{DynamicResource WizOptRoot}" 
                                  IsChecked="{Binding BackupRootCustomFolders}" 
                                  IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                  Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="0,6,0,0"/>

                        <!-- Custom Folders/Files Manual Selection ListBox -->
                        <Border Height="110" Margin="0,8,0,0" BorderBrush="#3058A6FF" BorderThickness="1" Background="#0DFFFFFF" CornerRadius="4"
                                Visibility="{Binding BackupRootCustomFolders, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox ItemsSource="{Binding CustomItemsToBackup}" Background="Transparent" BorderThickness="0" 
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" 
                                                  IsEnabled="{Binding DataContext.IsBackingUp, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                                  Foreground="White" FontSize="11" Margin="2,1">
                                            <CheckBox.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <!-- Preview Panel (Visible when IsPreviewVisible == True and IsBackingUp == False) -->
                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPreviewVisible}" Value="True"/>
                                            <Condition Binding="{Binding IsBackingUp}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="{DynamicResource LabelBackupPreviewTitle}" Style="{StaticResource MetricLabel}" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        
                        <Border Grid.Row="1" BorderBrush="#3058A6FF" BorderThickness="1.5" Background="#0DFFFFFF" CornerRadius="6" Padding="6">
                            <ListBox ItemsSource="{Binding PreviewItems}" Background="Transparent" BorderThickness="0" 
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SourcePath}" Foreground="#8B949E" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding SizeInfo}" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Active Progress Panel (Visible when IsBackingUp == True) -->
                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{Binding BackupStatus}" Foreground="White" FontSize="12" Margin="0,0,0,8" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                        <ProgressBar Grid.Row="1" Value="{Binding BackupProgress}" Height="10" Foreground="#FF17C3B2" Background="#20FFFFFF" Margin="0,0,0,15"/>
                        
                        <!-- Neon Tech Console Log Window -->
                        <Border Grid.Row="2" Background="#EE050B14" BorderBrush="#3058A6FF" BorderThickness="1.5" CornerRadius="6" Padding="8">
                            <ListBox x:Name="LogConsole" ItemsSource="{Binding BackupLogs}" 
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Focusable="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas, Lucida Console, Courier New" FontSize="10" Foreground="#00FF66"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Wizard Controls (Row 2) -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <!-- CONFIG STATE BUTTONS -->
                            <!-- Cancel Wizard Button (Closes wizard) -->
                            <Button Command="{Binding CancelBackupWizardCommand}" Width="Auto" MinWidth="100" Height="32" Margin="0,0,10,0" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnCancel}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsBackingUp}" Value="False"/>
                                                    <Condition Binding="{Binding IsPreviewVisible}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Scan & Preview Button -->
                            <Button Command="{Binding ShowPreviewCommand}" Width="Auto" MinWidth="140" Height="32" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GreenButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnPreviewFiles}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsBackingUp}" Value="False"/>
                                                    <Condition Binding="{Binding IsPreviewVisible}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- PREVIEW STATE BUTTONS -->
                            <!-- Go Back Button (Return to configurations) -->
                            <Button Command="{Binding CancelPreviewCommand}" Width="Auto" MinWidth="100" Height="32" Margin="0,0,10,0" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnGoBack}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsBackingUp}" Value="False"/>
                                                    <Condition Binding="{Binding IsPreviewVisible}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Confirm and Start Backup Button -->
                            <Button Command="{Binding StartWizardBackupCommand}" Width="Auto" MinWidth="140" Height="32" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GreenButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnStartBackup}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsBackingUp}" Value="False"/>
                                                    <Condition Binding="{Binding IsPreviewVisible}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- ACTIVE BACKUP STATE BUTTONS -->
                            <!-- Pause Backup Button -->
                            <Button Command="{Binding PauseBackupCommand}" Width="Auto" MinWidth="100" Height="32" Margin="0,0,10,0" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnPause}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsBackupPaused}" Value="True">
                                                <Setter Property="Content" Value="{DynamicResource BtnResume}"/>
                                                <Setter Property="Background" Value="#FF9F1C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Stop/Abort Backup Button -->
                            <Button Command="{Binding StopBackupCommand}" Width="Auto" MinWidth="100" Height="32" Padding="15,2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                        <Setter Property="Content" Value="{DynamicResource BtnStop}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
