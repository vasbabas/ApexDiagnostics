<Application x:Class="ApexDiagnostics.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:ApexDiagnostics.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Resources/Strings.en.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <helpers:StatusColorConverter x:Key="StatusColorConverter"/>
            <helpers:StatusTextConverter x:Key="StatusTextConverter"/>
            <helpers:ThrottleBgConverter x:Key="ThrottleBgConverter"/>
            <helpers:ThrottleTextConverter x:Key="ThrottleTextConverter"/>
            <helpers:ErrorColorConverter x:Key="ErrorColorConverter"/>
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <helpers:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <helpers:ExpanderSymbolConverter x:Key="ExpanderSymbolConverter"/>
            <helpers:StartButtonVisibilityConverter x:Key="StartButtonVisibilityConverter"/>
            <helpers:StopButtonVisibilityConverter x:Key="StopButtonVisibilityConverter"/>
            <helpers:StringStartsWithConverter x:Key="StringStartsWithConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
