<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Navigation Sidebar -->
    <system:String x:Key="NavDashboard">PANEL</system:String>
    <system:String x:Key="NavCpuTest">PRUEBA DE ESTRÉS CPU</system:String>
    <system:String x:Key="NavRamTest">DIAGNÓSTICO RAM</system:String>
    <system:String x:Key="NavDiskScan">ANÁLISIS DE SUPERFICIE</system:String>
    <system:String x:Key="NavSystemInfo">INFO SISTEMA</system:String>
    <system:String x:Key="NavExplorer">GESTOR DE ARCHIVOS</system:String>
    <system:String x:Key="NavClone">CLONADOR DE DISCO</system:String>
    
    <!-- Dashboard Titles & Stats -->
    <system:String x:Key="TitleDashboard">RESUMEN GENERAL</system:String>
    <system:String x:Key="StatCpuLoad">CARGA DE CPU EN TIEMPO REAL</system:String>
    <system:String x:Key="StatRamUsage">USO RAM FÍSICO</system:String>
    <system:String x:Key="StatDiskHealth">TEMPERATURA DEEP DE DISCO</system:String>
    <system:String x:Key="SystemSummary">ESTADO DE TELEMETRÍA DEL HARDWARE</system:String>
    
    <!-- CPU Torture Test -->
    <system:String x:Key="TitleCpuTest">ESTRÉS Y VALIDACIÓN DE CPU</system:String>
    <system:String x:Key="LabelCpuStatus">ESTADO</system:String>
    <system:String x:Key="LabelElapsedTime">TRANSCURRIDO</system:String>
    <system:String x:Key="LabelCpuPower">POTENCIA</system:String>
    <system:String x:Key="LabelInstructions">INSTRUCCIONES</system:String>
    <system:String x:Key="BtnStartTest">INICIAR PRUEBA</system:String>
    <system:String x:Key="BtnStopTest">DETENER PRUEBA</system:String>
    <system:String x:Key="CpuUsageHistory">HISTORIAL DE CARGA CPU (%)</system:String>
    <system:String x:Key="CpuTempHistory">HISTORIAL TEMP CPU (°C)</system:String>
    
    <!-- RAM Diagnostics -->
    <system:String x:Key="TitleRamTest">PRUEBA DE TOXICIDAD DE MEMORIA</system:String>
    <system:String x:Key="LabelRamAllocated">ASIGNADA</system:String>
    <system:String x:Key="LabelRamCoverage">COBERTURA</system:String>
    <system:String x:Key="LabelMemoryToxicity">ESTADO DE SALUD DE MEMORIA</system:String>
    
    <!-- Disk Surface Scan -->
    <system:String x:Key="TitleDiskScan">VERIFICADOR SUPERFICIE DISCO PRO</system:String>
    <system:String x:Key="SelectPhysicalDisk">SELECCIONAR DISCO FÍSICO</system:String>
    <system:String x:Key="BtnStartScan">INICIAR ANÁLISIS</system:String>
    <system:String x:Key="BtnStopScan">DETENER ANÁLISIS</system:String>
    <system:String x:Key="LabelBadSectors">SECTORES DAÑADOS</system:String>
    <system:String x:Key="LabelScanSpeed">VELOCIDAD ANÁLISIS</system:String>
    
    <!-- System Info -->
    <system:String x:Key="TitleSystemInfo">INVENTARIO GLOWING DE COMPONENTES</system:String>
    <system:String x:Key="ClickToCopy">Haga clic en un valor para copiar al portapapeles</system:String>
    
    <!-- Data Recovery & Backup Wizard -->
    <system:String x:Key="TitleExplorer">ASISTENTE DE RECUPERACIÓN APEX</system:String>
    <system:String x:Key="BtnBackupWizard">ASISTENTE DE RESCATE RÁPIDO</system:String>
    <system:String x:Key="WizardTitle">ASISTENTE DE RECUPERACIÓN ASÍNCRONO APEX</system:String>
    <system:String x:Key="WizSelectProfile">1. Seleccionar el perfil de usuario a rescatar</system:String>
    <system:String x:Key="WizSelectDest">2. Seleccionar el disco destino de la copia</system:String>
    <system:String x:Key="WizSelectOptions">3. Configurar opciones del motor de copia</system:String>
    <system:String x:Key="WizOptCreds">Respaldar credenciales de Windows &amp; llaves DPAPI</system:String>
    <system:String x:Key="WizOptRoot">Escanear &amp; Rescatar carpetas personalizadas de C:\</system:String>
    <system:String x:Key="BtnStartRescue">INICIAR RESCATE</system:String>
    <system:String x:Key="BtnCancel">CANCELAR</system:String>
    
    <!-- Disk Cloner -->
    <system:String x:Key="TitleClone">DUPLICADOR Y CLONADOR DE DISCO DE SECTORES</system:String>
    <system:String x:Key="TitleCloneDesc">Replicación sector por sector para restauración bare-metal y migraciones.</system:String>
    <system:String x:Key="BtnRefreshDrives">REFRESCAR DISCOS</system:String>
    <system:String x:Key="BtnStartCloning">INICIAR CLONACIÓN</system:String>
    <system:String x:Key="SelectSourceDisk">ELEGIR DISCO ORIGEN (LEER DESDE)</system:String>
    <system:String x:Key="SelectTargetDisk">ELEGIR DISCO DESTINO (ESCRIBIR EN)</system:String>
    <system:String x:Key="CloningInfoTitle">💠 TELEMETRÍA DE CLONACIÓN FÍSICA AVANZADA</system:String>
    <system:String x:Key="CloningInfo1">• Clonación Bare-Metal: Copia exacta sector por sector de archivos del sistema, particiones ocultas, layouts GPT/MBR y permisos.</system:String>
    <system:String x:Key="CloningInfo2">• Optimizado para WinPE: Escritura de bloques por acceso a hardware directo mediante buffer doble de 4 MB.</system:String>
    <system:String x:Key="CloningInfo3">• Tamaño del disco: Asegúrese de que el disco destino sea del mismo tamaño o mayor que el de origen.</system:String>
    <system:String x:Key="CloneTelemetryTitle">MONITOR DE TELEMETRÍA EN TIEMPO REAL</system:String>
    <system:String x:Key="CloneSpeed">VELOCIDAD DE CLONACIÓN</system:String>
    <system:String x:Key="CloneTimeRemaining">TIEMPO RESTANTE</system:String>
    <system:String x:Key="CloneSourceIndex">ÍNDICE ORIGEN</system:String>
    <system:String x:Key="CloneTargetIndex">ÍNDICE DESTINO</system:String>
    <system:String x:Key="CloneWarningTitle">🚨 ALERTA CRÍTICA DE PÉRDIDA DE DATOS</system:String>
    <system:String x:Key="CloneWarningSubtitle">La clonación a bajo nivel de sectores borrará toda información existente.</system:String>
    <system:String x:Key="CloneWarningText">ADVERTENCIA: Esta operación destruirá irreversiblemente todos los archivos, particiones y sistemas operativos del disco destino.</system:String>
    <system:String x:Key="CloneWarningConfirmText">Escriba 'CLONE' en el campo inferior para confirmar su intención:</system:String>
    <system:String x:Key="BtnWipeClone">BORRAR Y CLONAR</system:String>
</ResourceDictionary>
