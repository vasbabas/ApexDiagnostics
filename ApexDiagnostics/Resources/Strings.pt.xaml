<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Navigation Sidebar -->
    <system:String x:Key="NavDashboard">PAINEL</system:String>
    <system:String x:Key="NavCpuTest">ESTRESSE CPU &amp; VAL</system:String>
    <system:String x:Key="NavRamTest">DIAGNÓSTICO RAM</system:String>
    <system:String x:Key="NavDiskScan">ANÁLISE DE SUPERFÍCIE</system:String>
    <system:String x:Key="NavSystemInfo">INFO SISTEMA</system:String>
    <system:String x:Key="NavExplorer">GERENCIADOR DE ARQUIVOS</system:String>
    <system:String x:Key="NavClone">CLONADOR DE DISCO</system:String>
    
    <!-- Dashboard Titles & Stats -->
    <system:String x:Key="TitleDashboard">VISÃO GERAL DO SISTEMA</system:String>
    <system:String x:Key="StatCpuLoad">CARGA DA CPU EM TEMPO REAL</system:String>
    <system:String x:Key="StatRamUsage">USO FÍSICO DE RAM</system:String>
    <system:String x:Key="StatDiskHealth">TEMPERATURA PROFUNDA DO DISCO</system:String>
    <system:String x:Key="SystemSummary">ESTADO DE TELEMETRIA DO MOTOR DE HARDWARE</system:String>
    
    <!-- CPU Torture Test -->
    <system:String x:Key="TitleCpuTest">ESTRESSE E VALIDAÇÃO DE CPU</system:String>
    <system:String x:Key="LabelCpuStatus">STATUS</system:String>
    <system:String x:Key="LabelElapsedTime">DECORRIDO</system:String>
    <system:String x:Key="LabelCpuPower">POTÊNCIA</system:String>
    <system:String x:Key="LabelInstructions">INSTRUÇÕES</system:String>
    <system:String x:Key="BtnStartTest">INICIAR TESTE</system:String>
    <system:String x:Key="BtnStopTest">PARAR TESTE</system:String>
    <system:String x:Key="CpuUsageHistory">HISTÓRICO DE CARGA CPU (%)</system:String>
    <system:String x:Key="CpuTempHistory">HISTÓRICO DE TEMP CPU (°C)</system:String>
    
    <!-- RAM Diagnostics -->
    <system:String x:Key="TitleRamTest">DIAGNÓSTICO TOXICIDADE DE MEMÓRIA</system:String>
    <system:String x:Key="LabelRamAllocated">ALOCADA</system:String>
    <system:String x:Key="LabelRamCoverage">COBERTURA</system:String>
    <system:String x:Key="LabelMemoryToxicity">ESTADO DE SAÚDE DA MEMÓRIA</system:String>
    
    <!-- Disk Surface Scan -->
    <system:String x:Key="TitleDiskScan">VERIFICADOR SUPERFÍCIE DISCO PRO</system:String>
    <system:String x:Key="SelectPhysicalDisk">SELECIONAR DISCO FÍSICO</system:String>
    <system:String x:Key="BtnStartScan">INICIAR VARREDURA</system:String>
    <system:String x:Key="BtnStopScan">PARAR VARREDURA</system:String>
    <system:String x:Key="LabelBadSectors">SETORES DANIFICADOS</system:String>
    <system:String x:Key="LabelScanSpeed">VELOCIDADE DE VARREDURA</system:String>
    
    <!-- System Info -->
    <system:String x:Key="TitleSystemInfo">INVENTÁRIO GLOWING DE COMPONENTES</system:String>
    <system:String x:Key="ClickToCopy">Clique em um valor para copiá-lo para a área de transferência</system:String>
    
    <!-- Data Recovery & Backup Wizard -->
    <system:String x:Key="TitleExplorer">ASSISTENTE DE RECUPERAÇÃO DE DADOS APEX</system:String>
    <system:String x:Key="BtnBackupWizard">ASSISTENTE DE RESCATE RÁPIDO</system:String>
    <system:String x:Key="WizardTitle">ASSISTENTE DE RECUPERAÇÃO ASSÍNCRONO APEX</system:String>
    <system:String x:Key="WizSelectProfile">1. Selecione o perfil de usuário a ser resgatado</system:String>
    <system:String x:Key="WizSelectDest">2. Selecione a unidade destino da cópia</system:String>
    <system:String x:Key="WizSelectOptions">3. Configurar opções do motor de cópia</system:String>
    <system:String x:Key="WizOptCreds">Backup credenciais Windows salvas &amp; chaves DPAPI</system:String>
    <system:String x:Key="WizOptRoot">Escanear &amp; Resgatar pastas personalizadas de C:\</system:String>
    <system:String x:Key="BtnStartRescue">INICIAR RESGATE</system:String>
    <system:String x:Key="BtnCancel">CANCELAR</system:String>
    
    <!-- Disk Cloner -->
    <system:String x:Key="TitleClone">DUPLICADOR E CLONADOR DE DISCOS EM SETORES</system:String>
    <system:String x:Key="TitleCloneDesc">Replicação setor por setor para restauração bare-metal e migrações.</system:String>
    <system:String x:Key="BtnRefreshDrives">ATUALIZAR UNIDADES</system:String>
    <system:String x:Key="BtnStartCloning">INICIAR CLONAGEM</system:String>
    <system:String x:Key="SelectSourceDisk">SELECIONE UNIDADE ORIGEM (LER DE)</system:String>
    <system:String x:Key="SelectTargetDisk">SELECIONE UNIDADE DESTINO (ESCREVER EM)</system:String>
    <system:String x:Key="CloningInfoTitle">💠 TELEMETRIA DE CLONAGEM FÍSICA AVANÇADA</system:String>
    <system:String x:Key="CloningInfo1">• Clonagem Bare-Metal: A cópia espelho setor por setor preserva todos os arquivos, partições EFI ocultas, layouts e permissões.</system:String>
    <system:String x:Key="CloningInfo2">• Otimizado para WinPE: Gravação por acesso direto ao hardware usando buffers duplos de 4 MB a alta velocidade.</system:String>
    <system:String x:Key="CloningInfo3">• Capacidade mínima: Certifique-se de que a unidade de destino seja do mesmo tamanho ou maior que a de origem!</system:String>
    <system:String x:Key="CloneTelemetryTitle">MONITOR DE TELEMETRIA EM TEMPO REAL</system:String>
    <system:String x:Key="CloneSpeed">VELOCIDADE DE CLONAGEM</system:String>
    <system:String x:Key="CloneTimeRemaining">TEMPO RESTANTE</system:String>
    <system:String x:Key="CloneSourceIndex">ÍNDICE ORIGEM</system:String>
    <system:String x:Key="CloneTargetIndex">ÍNDICE DESTINO</system:String>
    <system:String x:Key="CloneWarningTitle">🚨 ALERTA CRÍTICO DE PERDA DE DADOS</system:String>
    <system:String x:Key="CloneWarningSubtitle">A clonagem de setores a baixo nível apagará toda informação existente.</system:String>
    <system:String x:Key="CloneWarningText">AVISO: Esta operação destruirá de forma irreversível todos os arquivos, partições e sistemas contidos na unidade destino!</system:String>
    <system:String x:Key="CloneWarningConfirmText">Digite 'CLONE' no campo inferior para confirmar:</system:String>
    <system:String x:Key="BtnWipeClone">BORRAR E CLONAR</system:String>
</ResourceDictionary>
